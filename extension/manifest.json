{
  "manifest_version": 3,
  "name": "Review Authenticity Lab",
  "version": "1.0.0",
  "description": "Analyzes product reviews on e-commerce sites to identify suspicious review patterns.",
  
  "action": {
    "default_popup": "dist/extension/ui/popup.html",
    "default_title": "Review Authenticity Lab"
  },

  "side_panel": {
    "default_path": "dist/extension/ui/sidepanel.html"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.ca/*",
        "https://play.google.com/store/apps/*"
      ],
      "js": [
        "content/content.js"
      ],
      "type": "module",
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "sidePanel",
    "storage"
  ]
}
