{
  "manifest_version": 3,
  "name": "Review Authenticity Lab",
  "version": "0.1.0",
  "description": "Analyzes product reviews on Amazon and Google Play to detect suspicious patterns using on-device AI.",

  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "Review Authenticity Lab"
  },

  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.ca/*",
        "https://play.google.com/store/apps/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "type": "module"
    }
  ],

  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.ca/*",
    "https://play.google.com/store/apps/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "models/*",
        "assets/*"
      ],
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.ca/*",
        "https://play.google.com/store/apps/*"
      ]
    }
  ]
}
